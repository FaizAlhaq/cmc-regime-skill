# ── Secrets — NEVER commit (CMC key safety) ──────────────────────────────
.env
.env.*
*.key

# ── Raw market data — CMC ToS forbids redistribution. Fetch locally with ──
#    your own key. The SYNTHETIC sample regenerates deterministically offline.
*.parquet
data/cache/
*.bundle

# ── Results: ignore everything, then un-ignore ONLY the two ToS-safe ──────
#    derived-analytics files for the locked real run (aggregate metrics +
#    regime model — NO raw OHLCV rows). Bar-level series.csv stays ignored.
results/*
!results/BTC_daily_REAL/
results/BTC_daily_REAL/*
!results/BTC_daily_REAL/report.md
!results/BTC_daily_REAL/strategy_spec.json
series.csv

